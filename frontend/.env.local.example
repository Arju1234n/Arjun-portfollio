# Environment Variables Template
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git (it's in .gitignore).

# =====================================================
# REQUIRED for database features (future)
# =====================================================
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>

# =====================================================
# REQUIRED for contact form email delivery (pick one)
# =====================================================
# Option A — Resend (recommended): https://resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxx
# CONTACT_EMAIL=kumararjun5230@gmail.com

# Option B — SMTP (Gmail example)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-gmail@gmail.com
# SMTP_PASS=your-app-password     # Generate at myaccount.google.com/apppasswords
# CONTACT_EMAIL=kumararjun5230@gmail.com

# =====================================================
# OPTIONAL — Cloudinary (image CDN)
# =====================================================
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=xxxxxxxxxxxx
# CLOUDINARY_API_SECRET=xxxxxxxxxxxx

# =====================================================
# OPTIONAL — Analytics / Monitoring
# =====================================================
# NEXT_PUBLIC_ANALYTICS_ID=G-XXXXXXXXXX
